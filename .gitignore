checkpoints/

# TensorBoard logs (inside checkpoints, but just in case)
runs/

# Evaluation results (regeneratable)
results/*
!results/.gitkeep

# PyTorch / HuggingFace model weights
*.pt
*.pth
*.bin
*.safetensors
*.gguf
*.ggml

# HuggingFace cache
.cache/

# Data — raw downloads (large, re-downloadable)
data/raw/*
!data/raw/.gitkeep

# Processed data (regeneratable, can be large)
data/processed/*
!data/processed/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDEs
